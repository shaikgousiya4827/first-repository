        "str=\"loveleetcode\"\n",
        "str.lower()\n",
        "count=0\n",
        "for i in str:\n",
        "  if str.count(i)==1:\n",
        "    print(f\"0 \\n{i} appears only once and its index is {str.index(i)}\")\n",
        "    break\n",
        "  elif str.count(i)>1:\n",
        "    count+=1\n",
        "    continue\n",
        "  else:\n",
        "    print(\"-1 \\n All characters are repeated\")"
      ],
